# URL da API do back-end
# Desenvolvimento:
VITE_API_URL=http://localhost:3000/api

# Producao (substituir pela URL real do back no Vercel):
# VITE_API_URL=https://api-waltrix.vercel.app/api

# Nunca inclua rotas de tela aqui, como /login/api. Use apenas a raiz da API.

# Chaves de IA (adicionar no painel do Vercel em Settings > Environment Variables)
VITE_GEMINI_API_KEY=<sua-chave-gemini>
VITE_GROQ_API_KEY=<sua-chave-groq>
VITE_MISTRAL_API_KEY=<sua-chave-mistral>
