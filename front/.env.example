# URL da API do back-end
# Desenvolvimento:
VITE_API_URL=http://localhost:3000/api

# Producao (substituir pela URL real do back no Vercel):
# VITE_API_URL=https://api-waltrix.vercel.app/api

# Nunca inclua rotas de tela aqui, como /login/api. Use apenas a raiz da API.
# As chaves de IA ficam SOMENTE no backend (back/src/.env) — nunca no frontend.
