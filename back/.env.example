# ──────────────────────────────────────────
# Waltrix — Variáveis de Ambiente (exemplo)
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────

# Servidor
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remetente — deve usar o domínio verificado no Resend (waltrix.com.br)
FROM_EMAIL=noreply@waltrix.com.br

# URL do frontend (usada nos links dos e-mails)
FRONTEND_URL=https://waltrix.com.br

# Origins permitidas pelo CORS (separadas por vírgula, opcional)
# ALLOWED_ORIGINS=https://meudominio.com
