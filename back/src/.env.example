# Porta local (o Vercel/Railway ignora isso e define a porta automaticamente)
PORT=3000

# String de conexão do MongoDB Atlas
# Crie um cluster em https://cloud.mongodb.com e copie a connection string
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?appName=Web-Wallet

# Segredo para assinar os tokens JWT — use uma string longa e aleatória
JWT_SECRET=<segredo-jwt-aqui>

# Origens permitidas pelo CORS (separadas por vírgula)
# Desenvolvimento:
ALLOWED_ORIGINS=http://localhost:5173
# Produção (substituir pela URL real do front):
# ALLOWED_ORIGINS=https://waltrix.com.br,https://www.waltrix.com.br

# SendGrid — para envio de e-mails (ex: recuperação de senha)
SENDGRID_API_KEY=SG.<sua-chave-aqui>
SENDGRID_FROM_EMAIL=noreply@waltrix.com.br

# URL do front-end (usada nos links enviados por e-mail)
# Desenvolvimento:
FRONTEND_URL=http://localhost:5173
# Produção:
# FRONTEND_URL=https://waltrix.com.br
