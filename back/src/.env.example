# Porta local (o Vercel/Railway ignora isso e define a porta automaticamente)
PORT=3000

# String de conexão do MongoDB Atlas
# Crie um cluster em https://cloud.mongodb.com e copie a connection string
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?appName=Web-Wallet

# Segredo para assinar os tokens JWT — use uma string longa e aleatória
JWT_SECRET=<segredo-jwt-aqui>

# Origens permitidas pelo CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://waltrix.com.br,https://www.waltrix.com.br,https://web-wallet-orcin.vercel.app

# Resend — para envio de e-mails (verificação de conta e código de reset de senha)
# Crie a chave em https://resend.com/api-keys (formato: re_...)
RESEND_API_KEY=re_<sua-chave-aqui>
# Remetente: precisa ser um domínio/endereço VERIFICADO no Resend.
# Para testes rápidos use onboarding@resend.dev (só envia para o e-mail dono da conta Resend).
FROM_EMAIL=noreply@waltrix.com.br

# URL do front-end (usada no link de verificação de e-mail enviado no cadastro)
# Desenvolvimento:
FRONTEND_URL=http://localhost:5173
# Produção:
# FRONTEND_URL=https://waltrix.com.br

# Chaves de IA — proxy seguro para o frontend (NUNCA exponha no frontend)
# Obtenha em: https://aistudio.google.com | https://console.groq.com | https://console.mistral.ai
GEMINI_API_KEY=<sua-chave-gemini>
GROQ_API_KEY=<sua-chave-groq>
MISTRAL_API_KEY=<sua-chave-mistral>
